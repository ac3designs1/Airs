# ── NextAirs Backend Environment Variables ────────────────────
# Set these in Railway: Project → Variables

# JWT Secret (REQUIRED) — generate: node -e "require('crypto').randomBytes(64).toString('hex')|console.log"
JWT_SECRET=REPLACE_WITH_STRONG_64_BYTE_HEX_SECRET

# Port (Railway sets this automatically — leave as 3001 for local)
PORT=3001

# Allowed frontend origins — add your Vercel URL here
# Multiple origins separated by comma
# e.g. https://nextairs.vercel.app,http://localhost:5173
CORS_ORIGIN=http://localhost:5173

PORT=3001
JWT_SECRET=replace-with-a-long-random-secret
CORS_ORIGIN=http://localhost:5173,https://your-project.vercel.app# NextAirs Environment Configuration — copy to .env and fill in values

# JWT Secret — generate with: node -e "require('crypto').randomBytes(64).toString('hex')|console.log"
JWT_SECRET=REPLACE_WITH_STRONG_64_BYTE_HEX_SECRET

# Server port
PORT=3001

# Allowed CORS origins (comma-separated)
# Dev:  http://localhost:5173
# Prod: https://mdt.yourdomain.com
CORS_ORIGIN=http://localhost:5173

# ── NextAirs Backend Environment Variables ────────────────────
# Set these in Railway: Project → Variables

# JWT Secret (REQUIRED) — generate: node -e "require('crypto').randomBytes(64).toString('hex')|console.log"
JWT_SECRET=REPLACE_WITH_STRONG_64_BYTE_HEX_SECRET

# Port (Railway sets this automatically — leave as 3001 for local)
PORT=3001

# Allowed frontend origins — add your Vercel URL here
CORS_ORIGIN=http://localhost:5173

# Discord OAuth — create app at https://discord.com/developers/applications
DISCORD_CLIENT_ID=YOUR_DISCORD_CLIENT_ID
DISCORD_CLIENT_SECRET=YOUR_DISCORD_CLIENT_SECRET

# Discord Bot Token — for sending DMs (interview invites etc.)
# Create a bot at discord.com/developers → your app → Bot → Reset Token
# Add the bot to your server with "Send Messages" permission
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN

# Public URLs (no trailing slash)
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001

# FiveM MDT Integration — set this in Railway and in jay_mdt sh_config.lua
FIVEM_API_KEY=REPLACE_WITH_YOUR_FIVEM_API_KEY
